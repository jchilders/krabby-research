[run]
# Measure from the repo root; run pytest from that root (e.g. /workspace in the test image).
source = .

omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */.*
    */site-packages/*
    */dist-packages/*
    */venv/*
    */env/*
    */testenv/*
    */build/*
    */build/lib/*
    */*.egg-info/*
    # Top-level and nested ``parkour/`` trees (tasks, Isaac Lab envs, vendored scripts)
    parkour/*
    */parkour/*
    # Docker / CI glue, not primary library code
    */images/*
    */.build-cache/*
    # Compute test harness (runner, mocks, etc.; not product libraries)
    */compute/testing/*
    # One-off CLIs and examples
    */scripts/*
    # HAL verification CLIs (see docs; not core server/client libraries)
    */hal/tools/*
    # Process entrypoints (``python -m pkg`` / deployment mains), not libraries under test
    */main.py
    */__main__.py
    # Package markers / re-exports (usually thin)
    */__init__.py

[report]
# Exclude lines from coverage report
exclude_lines =
    # Have to re-enable the standard pragma
    pragma: no cover

    # Don't complain about missing debug-only code
    def __repr__
    if self.debug

    # Don't complain if tests don't hit defensive assertion code
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run
    if 0:
    if __name__ == .__main__.:
    if TYPE_CHECKING:

    # Don't complain about abstract methods
    @abstractmethod

# Precision for coverage percentages
precision = 2

# Show missing line numbers
show_missing = True

# Skip files with no executable lines (e.g. docstring-only __init__.py)
skip_empty = True

[html]
# Directory for HTML coverage report
directory = tests/coverage/htmlcov
